#! /bin/sh

name=libxml2
version=2.15.3
revision=1
tarball_url="https://gitlab.gnome.org/GNOME/libxml2/-/archive/v${version}/libxml2-v${version}.tar.gz"
tarball_blake2b="118454ed4ea904a74ba7fab7d529b0823835c0b38b57bec2de1b72d386f9818f90119e0b794d0743a92f562f9ced2552616ecaaaf6ffd35baa41deaefd2199be"
hostdeps="gcc pkg-config"
deps="core-libs icu readline zlib"

configure() {
    meson_configure \
        -Dpython=disabled \
        -Dhistory=enabled \
        -Dicu=enabled \
        -Dreadline=enabled \
        -Dzlib=enabled
}

build() {
    meson compile -j${parallelism}
}

package() {
    DESTDIR="${dest_dir}" meson install --no-rebuild

    post_package_strip
}
