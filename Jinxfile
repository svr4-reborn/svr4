#!/bin/sh

JINX_MAJOR_VER=0.8
JINX_DEBIAN_SNAPSHOT="20251020T082908Z"
JINX_BASE_PACKAGES="autopoint bison cmake docbook-xsl docbook-xml docbook-xsl-ns docbook5-xml doxygen file flex gettext
                    m4 make mercurial meson ninja-build perl python3 texinfo w3m which xmlto xsltproc"

HOST_ARCH="$(uname -m)"
HOST_TRIPLET=${HOST_ARCH}-unknown-linux-gnu

HOST_CFLAGS="-O2 -pipe -fPIC -fPIE"
HOST_CXXFLAGS="${HOST_CFLAGS} -Wp,-D_GLIBCXX_ASSERTIONS"
HOST_LDFLAGS="-Wl,-O1 -Wl,--sort-common -Wl,--as-needed -Wl,-z,now"

# TODO: determine what target CFLAGS we will use
TARGET_CFLAGS="-O2 -pipe -fPIC -fPIE"
TARGET_CXXFLAGS="${TARGET_CFLAGS} -Wp,-D_GLIBCXX_ASSERTIONS"
TARGET_LDFLAGS="-Wl,-O1 -Wl,--sort-common -Wl,--as-needed -Wl,-z,now"

OS_TRIPLET=${JINX_ARCH}-svr4-mlibc

case "${JINX_ARCH}" in
    i?86)
        TARGET_CFLAGS="${TARGET_CFLAGS} -m32 -mno-mmx -mno-sse -mno-sse2"
        TARGET_CXXFLAGS="${TARGET_CXXFLAGS} -m32 -mno-mmx -mno-sse -mno-sse2"
        TARGET_LDFLAGS="${TARGET_LDFLAGS} -m32"
        ;;
    *)
        echo "Unsupported architecture: ${JINX_ARCH}"
        exit 1
        ;;
esac

post_package_strip() {
    if [ -z "$strip_command" ]; then
        strip_command="${OS_TRIPLET}-strip"
    fi

    for f in $(find "${dest_dir}"); do
        if file "$f" | grep 'not stripped' >/dev/null; then
            echo "* stripping '$f'..."
            stripped_file="$(mktemp)"
            ${strip_command} "$f" -o "$stripped_file"
            chmod --reference="$f" "$stripped_file"
            mv -f "$stripped_file" "$f"
        fi
    done
}

