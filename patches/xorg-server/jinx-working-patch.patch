 /*****************
  * CloseDownConnection
  *    Delete client from AllClients and free resources
  *****************/
 
 void
 CloseDownConnection(ClientPtr client)
 {
     OsCommPtr oc = (OsCommPtr) client->osPrivate;
+
+    ErrorF("xorg-svr4: CloseDownConnection client=%d state=%d gone=%d noexc=%d fd=%d\n",
+           client ? client->index : -1,
+           client ? client->clientState : -1,
+           client ? client->clientGone : -1,
+           client ? client->noClientException : -1,
+           oc ? oc->fd : -1);
 
     if (FlushCallback)
         CallCallbacks(&FlushCallback, client);
