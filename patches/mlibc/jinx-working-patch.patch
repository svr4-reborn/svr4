+#if defined(_DEFAULT_SOURCE) || __MLIBC_POSIX2024
+#define WCOREDUMP(x) ((x) & __WCOREFLAG)
+#endif /* defined(_DEFAULT_SOURCE) || __MLIBC_POSIX2024 */
